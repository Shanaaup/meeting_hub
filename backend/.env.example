# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Meeting Intelligence Hub"
SECRET_KEY=changeme_use_a_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev default — no config needed)
DATABASE_URL=sqlite+aiosqlite:///./data/meeting_hub.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meeting_hub

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
